# Copy to .env and fill in real values.

# Supabase direct connection — for drizzle-kit push (migrations/DDL)
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres

# Supabase transaction pooler — for the running API server (Railway)
DATABASE_URL_POOLED=postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-<REGION>.pooler.supabase.com:6543/postgres

PORT=3001
GEMINI_API_KEY=

# Web app API target. Use this when the frontend and API are deployed on different hosts.
# Examples:
# EXPO_PUBLIC_API_URL=https://your-api.up.railway.app/api
# EXPO_PUBLIC_API_BASE=https://your-api.up.railway.app/api
EXPO_PUBLIC_API_URL=
