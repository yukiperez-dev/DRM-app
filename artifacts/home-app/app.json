{
  "expo": {
    "name": "JF&Y",
    "slug": "home-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "home-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6EE"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.juanfespinal.homeapp"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow JF&Y to choose receipt images.",
          "cameraPermission": "Allow JF&Y to take receipt photos.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "bb44928d-64be-4ae0-8c06-07db2c148755"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bb44928d-64be-4ae0-8c06-07db2c148755"
    }
  }
}
